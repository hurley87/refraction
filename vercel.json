{
  "buildCommand": "yarn build",
  "installCommand": "yarn install --frozen-lockfile",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/update-airtable",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/spend-rail-reconcile",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/sponsored-settlement",
      "schedule": "* * * * *"
    }
  ]
}

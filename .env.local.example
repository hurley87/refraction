# Privy Configuration
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# WalletConnect / WalletKit — Pay page (app/walletconnect → /walletconnect)
# See: https://docs.walletconnect.com/payments/wallets/walletkit/web
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...   # required (same Cloud project as your wallet)
# NEXT_PUBLIC_WALLETCONNECT_PAY_APP_ID=...    # preferred: WCPay ID from Pay → Integrate
# NEXT_PUBLIC_WALLETCONNECT_PAY_API_KEY=...   # optional fallback: linked Pay API key from Pay → API Keys
#                                           # both must match the same Cloud project as PROJECT_ID; no quotes. Payment URI comes from QR on /walletconnect.
# NEXT_PUBLIC_POSTER_USDC_RECIPIENT_ADDRESS=0x...  # optional: receive $1 USDC on Base without a Pay link (ERC-20 transfer)

# Zora API Key (must be public for metadata interactions)
NEXT_PUBLIC_ZORA_API_KEY=your_zora_api_key_here

# Server wallet (0x… hex) for custodial / server-signed Base txs. Used by several API routes.
# Claim NFT (/api/claim-nft): must be the WalletCon NFT contract owner on Base and hold a little ETH for gas.
SERVER_WALLET_PRIVATE_KEY=your_private_key_here
# Alias — if set, used when SERVER_WALLET_PRIVATE_KEY is empty (same key, either name works):
# SERVER_PRIVATE_KEY=your_private_key_here

# Base RPC URL
BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org

# Mapbox
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Optional: explicit HMAC key for /api/admin/guides/.../preview-link (draft previews).
# If unset in production, a key is derived from PRIVY_APP_SECRET.
# GUIDE_PREVIEW_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

NEXT_PUBLIC_MIXPANEL_TOKEN=your_token_here
MIXPANEL_SECRET=your_project_secret_for_server_side

# Sentry (errors-first bootstrap)
# Public DSN for browser-side error capture; also used as fallback on server.
NEXT_PUBLIC_SENTRY_DSN=
# Optional dedicated server-side DSN (can match NEXT_PUBLIC_SENTRY_DSN).
SENTRY_DSN=
# Optional deployment metadata.
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Usually set to commit SHA in CI (e.g. $VERCEL_GIT_COMMIT_SHA).
SENTRY_RELEASE=
# Sentry source map upload (build-time).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Error noise filtering (comma-separated substrings).
SENTRY_IGNORE_ERRORS=
#
# Tracing stays OFF by default. Turn on only when ready:
# SENTRY_ENABLE_TRACING=true
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_SELECTED_ROUTE_SAMPLE_RATE=0.2
# SENTRY_TRACE_ROUTES=/api/claim-nft,/api/stripe-commons/claim,/api/stellar-wallet,/api/player

# Campaign Monitor — add new signups to a list (server-side, same pattern as Airtable).
# API key from Account settings → API keys; use as Basic auth username, password "x".
# List ID: list Settings → bottom of page (List API ID).
# CAMPAIGN_MONITOR_API_KEY=
# CAMPAIGN_MONITOR_LIST_ID=

# Stellar / Soroban: contract addresses are in lib/stellar/contract-addresses.ts.
# Set NEXT_PUBLIC_*_CONTRACT_ADDRESS_* only to override (e.g. per-environment).
# Key that signs the fungible-token claim transaction (server pays fees)
REWARDS_TOKEN_OWNER_SECRET_KEY=

# --- Spend rails (IRL Spend: Base USDC + Stellar USDC) ---
# Kill switches (default: Base on, Stellar off). When false or required vars are missing/invalid, new sessions and new money movement are blocked for that rail.
# SPEND_RAIL_BASE_USDC_ENABLED=true
# SPEND_RAIL_STELLAR_USDC_ENABLED=false
#
# Base USDC — treasury (Privy server wallet), receiving (settlement), optional overrides:
# SPEND_RAIL_BASE_USDC_TREASURY_WALLET_ADDRESS=0x...
# SPEND_RAIL_BASE_USDC_RECEIVING_WALLET_ADDRESS=0x...
# SPEND_RAIL_BASE_USDC_PRIVY_SERVER_WALLET_ID=...
# SPEND_RAIL_BASE_USDC_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# SPEND_RAIL_BASE_USDC_RPC_URL=https://mainnet.base.org
# NEXT_PUBLIC_SPEND_RAIL_BASE_USDC_EXPLORER_TX_URL_TEMPLATE=https://basescan.org/tx/{txHash}
#
# Stellar USDC — receiving (G… strkey); optional separate treasury; network for explorer defaults:
# SPEND_RAIL_STELLAR_USDC_RECEIVING_ADDRESS=G...
# SPEND_RAIL_STELLAR_USDC_TREASURY_ADDRESS=G...
# NEXT_PUBLIC_STELLAR_NETWORK=PUBLIC
# NEXT_PUBLIC_SPEND_RAIL_STELLAR_USDC_EXPLORER_TX_URL_TEMPLATE=https://stellar.expert/explorer/public/tx/{txHash}
# Optional Horizon override (validated only when set): NEXT_PUBLIC_STELLAR_HORIZON_URL=

# Claim NFT (WalletCon NFT on Base — see lib/walletcon-nft.ts): mock "mint open" for local UI testing.
# When set to "true", GET /api/claim-nft returns canMint: true, hasClaimed: false so the claim button appears.
# Do not set in production.
# MOCK_CLAIM_NFT_OPEN=true

# Claim success page: `/claim/success?preview=1` is styling-only (no mint); no env needed.